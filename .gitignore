# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
*.egg-info/
.pytest_cache/
.mypy_cache/
.ruff_cache/

# Virtualenvs
.venv/
venv/
env/
ENV/

# Environment / secrets
.env
.env.local
.env.*.local

# Databases (SQLite)
data/*.db
data/*.db-journal
data/*.sqlite
data/*.sqlite3

# SQLite backups(migration 留下的時戳備份檔)
data/*.bak.*
data/*.bak

# OS
.DS_Store
Thumbs.db

# IDE
.idea/
.vscode/
*.swp
*.swo

# Claude Code metadata
.claude/

# Debug / scratch outputs
scripts/out/

# One-off probe / scratch scripts(命名慣例:scripts/_* 不進 git,任何附檔名)
scripts/_*

# Mobile / verification screenshots(每次驗收會重產生,不進 repo)
screenshots/

# Session 工作日誌(自動模式內部紀錄,不進 repo)
docs/SESSION_LOG.md

# Design references / mockups (本地參考用,不進 repo)
design/

# Logs
*.log
logs/

# Temp curl/inspect outputs (verify-only, never commit)
_tmp*.html
_*.html
_*.json

# Root-only 圖片(user 截圖等)— 不擋 static/img 子目錄資產
/*.jpg
/*.jpeg
/*.png
