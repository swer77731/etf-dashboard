# --- Application ---
APP_NAME="ETF 觀察室"
APP_ENV=dev
DEBUG=true

# --- Server ---
HOST=127.0.0.1
PORT=8000

# --- Database ---
# Default: SQLite single file at ./data/etf.db
# DATABASE_URL=sqlite:///./data/etf.db

# --- Scheduler ---
SCHEDULER_TIMEZONE=Asia/Taipei
DAILY_FETCH_HOUR=14
DAILY_FETCH_MINUTE=30

# --- Data sources ---
# FinMind: https://finmindtrade.com/
# 免費版不填也能用(rate limit 較低),註冊後填 token 提高 rate limit
FINMIND_API_TOKEN=

# --- Telegram (Step 5) ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_ADMIN_CHAT_ID=

# --- Auth / Sessions (Step 6) ---
SECRET_KEY=change-me-in-production
